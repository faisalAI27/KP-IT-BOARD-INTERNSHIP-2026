APP_NAME=KP AWAZ API
API_PREFIX=/api
# DATABASE_URL is optional. When omitted, SQLite uses backend/kp_awaz.db.
FRONTEND_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
STORAGE_ROOT=storage
MAX_AUDIO_SIZE_MB=15
MAX_GUIDED_AUDIO_SIZE_MB=15
MAX_OPEN_AUDIO_SIZE_MB=50
AUDIO_STORAGE_SUBDIRECTORY=audio
MAX_IMPORT_FILE_SIZE_MB=5
MIN_IMPORTED_SENTENCE_LENGTH=3
MAX_IMPORTED_SENTENCE_LENGTH=500
ADMIN_API_KEY=dev-change-this-key

# Used by FastAPI when it verifies a user's Supabase Auth access token.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_AUTH_TIMEOUT_SECONDS=5

# Never use a Supabase service-role key in browser or frontend code.
